rules_version = '2';

// =============================================================================
// LeadScraper Pro — Regras de segurança do Firestore
// -----------------------------------------------------------------------------
// Princípio central: campos sensíveis (credits, isAdmin) e coleções de sistema
// (config, auditLog) NUNCA podem ser alterados diretamente pelo cliente —
// apenas pelas Cloud Functions, que usam o Admin SDK e por isso ignoram estas
// regras por completo. Isso fecha a falha de segurança que permitia, em
// teoria, qualquer usuário autenticado editar o próprio saldo de créditos (ou
// o de terceiros) escrevendo direto no Firestore pelo console do navegador —
// e é também a causa raiz dos botões de crédito que "não funcionavam": com
// regras corretas, a escrita direta do cliente é (corretamente) negada.
// =============================================================================

function isSignedIn() {
  return request.auth != null;
}

function isOwner(uid) {
  return isSignedIn() && request.auth.uid == uid;
}

function isAdmin() {
  return isSignedIn() &&
    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // users/{uid}
    // Leitura: o próprio usuário ou um admin.
    // Criação: NUNCA pelo cliente — o perfil é criado pela função
    //          onUserCreate (gatilho de Auth) com o Admin SDK.
    // Atualização: o próprio usuário pode editar nome/templates/tema, mas
    //          jamais credits ou isAdmin (esses só mudam via Cloud Function).
    // ---------------------------------------------------------------------
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if false;
      allow update: if isOwner(uid) &&
        request.resource.data.credits == resource.data.credits &&
        request.resource.data.isAdmin == resource.data.isAdmin &&
        request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // leads/{leadId}
    // Cada lead pertence a um único usuário (ownerUid). CRUD completo, mas
    // somente sobre os próprios leads — nunca sobre os de outro usuário.
    // ---------------------------------------------------------------------
    match /leads/{leadId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // messageLog/{id} — histórico de abordagens enviadas (item 8 do briefing)
    // ---------------------------------------------------------------------
    match /messageLog/{id} {
      allow read, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if false;
    }

    // ---------------------------------------------------------------------
    // config/global — limite de leads por busca etc.
    // Leitura liberada (a interface precisa exibir o limite atual a todos).
    // Escrita SOMENTE via Cloud Function updateGlobalConfig (Admin SDK).
    // ---------------------------------------------------------------------
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // auditLog/{id} — trilha de auditoria de créditos e ações administrativas
    // Leitura: somente admins. Escrita: somente Cloud Functions.
    // ---------------------------------------------------------------------
    match /auditLog/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Bloqueio padrão para qualquer coleção não listada explicitamente acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
